            {
                "s2_paper_id": "a3d4224c6e69f62c8e63299b46fc96bd722b4c38",
                "title": "Dimension-free estimates for semigroup BMO and A_p",
                "year": 2019,
                "venue": "Indiana University Mathematics Journal",
                "citation_count": 5,
                "reference_count": 18,
                "abstract": "Let $K_t$ be either the heat or the Poisson kernel on $\\mathbb{R}^n.$ Let $\\mathcal{A}$ stand either for BMO equipped with the quadratic seminorm or for $A_p,$ $1< p\\le\\infty.$ We establish the following transference between the class $\\mathcal{A}$ on an interval $I\\subset\\mathbb{R}$ and its $K$-version, $\\mathcal{A}^K,$ on $\\mathbb{R}^n$: If a given integral functional admits an estimate on $\\mathcal{A}(I),$ then the same estimate holds for $\\mathcal{A}^K(\\mathbb{R}^n),$ with all Lebesgue averages replaced by $K$-averages. In particular, all such estimates are dimension-free. As an application, we show that the John--Nirenberg constant of ${\\rm BMO}(\\mathbb{R}^n)$ on balls decays with dimension no faster than $n^{-1/2}.$",
                "authors": [
                    {
                        "s2_author_id": "38790176",
                        "name": "L. Slavin"
                    },
                    {
                        "s2_author_id": "2277245426",
                        "name": "Pavel Zatitskii"
                    }
                ]
            },
            {
                "s2_paper_id": "d121395d5fbdd6d72004ed11675c94708d42a3bc",
                "title": "THE BMO\u2192 BLO ACTION OF THE MAXIMAL OPERATOR ON \u03b1-TREES",
                "year": 2019,
                "venue": "",
                "citation_count": 1,
                "reference_count": 18,
                "abstract": null,
                "authors": [
