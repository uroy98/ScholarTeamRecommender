                    },
                    {
                        "s2_author_id": "89782907",
                        "name": "P. Zatitskiy"
                    }
                ]
            },
            {
                "s2_paper_id": "74d4a07cbc4897dcb4d61a4ae6e720b114c098f6",
                "title": "Sharp L^p estimates on BMO",
                "year": 2011,
                "venue": "",
                "citation_count": 57,
                "reference_count": 18,
                "abstract": "We construct the upper and lower Bellman functions for the $L^p$ (quasi)-norms of BMO functions. These appear as solutions to a series of Monge--Ampere boundary value problems on a non-convex plane domain. The knowledge of the Bellman functions leads to sharp constants in inequalities relating average oscillations of BMO functions and various BMO norms.",
                "authors": [
                    {
                        "s2_author_id": "38790176",
                        "name": "L. Slavin"
                    },
                    {
