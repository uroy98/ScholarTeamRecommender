            {
                "s2_paper_id": "7c2f829b44cb4b93475fc944a2da43a2eee9dee1",
                "title": "The automorphism group of a graph product with no SIL",
                "year": 2009,
                "venue": "",
                "citation_count": 38,
                "reference_count": 24,
                "abstract": "We study the automorphisms of graph products of cyclic groups, a class of groups that includes all right-angled Coxeter and right-angled Artin groups. We show that the group of automorphisms generated by partial conjugations is itself a graph product of cyclic groups providing its defining graph does not contain any separating intersection of links (SIL). In the case that all the cyclic groups are finite, this implies that the automorphism group is virtually CAT(0); it has a finite index subgroup which acts geometrically on a right-angled building.",
                "authors": [
                    {
                        "s2_author_id": "144747451",
                        "name": "Ruth Charney"
                    },
                    {
                        "s2_author_id": "48249142",
                        "name": "K. Ruane"
                    },
                    {
