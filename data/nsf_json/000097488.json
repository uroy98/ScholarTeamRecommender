            {
                "s2_paper_id": "6a1bfd92bb3abc26d8b29fd947f2c4971fd904ef",
                "title": "Local connectivity of right-angled Coxeter group boundaries",
                "year": 2007,
                "venue": "",
                "citation_count": 19,
                "reference_count": 17,
                "abstract": "Abstract We establish conditions on the defining graph of a right-angled Coxeter group presentation which guarantee that the boundary of any CAT(0) space on which the group acts geometrically will be locally connected.",
