        "papers": [
            {
                "s2_paper_id": "59843405b27ef6f3dda334faed0fb5e6220c19a7",
                "title": "Counting locally supercuspidal newforms",
                "year": 2025,
                "venue": "Essential Number Theory",
                "citation_count": 0,
                "reference_count": 29,
                "abstract": null,
                "authors": [
                    {
                        "s2_author_id": "71531601",
                        "name": "Andrew H. Knightly"
