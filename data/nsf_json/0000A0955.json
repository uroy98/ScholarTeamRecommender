            {
                "s2_paper_id": "73cf9b7842c1f7a231bb6f2e6f784c8f91598ce0",
                "title": "Waterworks on Tree Stems: The Wonders of Stemflow",
                "year": 2025,
                "venue": "EOS",
                "citation_count": 0,
                "reference_count": 0,
                "abstract": "Stemflow hydrodynamics offers rich physics that seeks to describe water and matter cycling within the atmosphere-biosphere-geosphere with implications for water resources planning.",
