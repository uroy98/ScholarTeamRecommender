        "papers": [
            {
                "s2_paper_id": "beea7c11c53c08fe53410036c2c08052147f6a9e",
                "title": "Challenges in Low Infrastructure and Off-Road Automated Driving",
                "year": 2022,
                "venue": "2022 Fifth International Conference on Connected and Autonomous Driving (MetroCAD)",
                "citation_count": 11,
                "reference_count": 0,
                "abstract": "Significant advances have been made in advanced driver assist systems (ADAS) and automated driving (AD) systems in recent decades. However, much of the progress has focused on vehicles operating in operational design domains with high level infrastructure, accurate and detailed mapping data, and smooth, firm driving surfaces. There are many stakeholders with significant interest in driving at human operating speeds in areas with limited or no infrastructure including off-road environments. This article discusses approaches to addressing outstanding challenges to developing and testing autonomous ground vehicles (AGVs) for effective operation with limited infrastructure and in off-road environments.",
                "authors": [
                    {
                        "s2_author_id": "144601570",
                        "name": "Daniel W. Carruth"
                    },
                    {
                        "s2_author_id": "37140293",
