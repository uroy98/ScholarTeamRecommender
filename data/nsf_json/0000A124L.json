                "title": "Book Review: Researching Learning and Teaching With Adults: An Introduction by Ralf St. Clair (Ed.)",
                "year": 2024,
                "venue": "New Horizons in adult education & Human resource development",
                "citation_count": 0,
                "reference_count": 14,
                "abstract": null,
