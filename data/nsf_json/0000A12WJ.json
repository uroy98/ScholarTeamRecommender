        "papers": [
            {
                "s2_paper_id": "227912ac32c49397ea9f9968be62cd4b3aad1c2b",
                "title": "Efficiency Limit of Transition Metal Dichalcogenide-Silicon Tandem Solar Cells",
                "year": 2025,
                "venue": "Photovoltaic Specialists Conference",
                "citation_count": 0,
                "reference_count": 0,
                "abstract": "Transition metal dichalcogenides (TMDs) have significant potential as top cell materials for tandem solar cells, due to their high optical absorption coefficients, desirable band gaps, and self-passivated surfaces. In this study, we evaluate the efficiency limits of four-terminal (4T) TMD-silicon tandem solar cells using MoS2, WS2, and WSe2 as the top cell absorber materials, paired with a high-performance crystalline silicon (c-Si) bottom cell with record efficiency of 26.7%. We employ a detailed balance model that incorporates experimental optical absorption data and accounts for radiative, Auger, and Shockley-Read-Hall (SRH) recombination mechanisms. Our results show that TMD-silicon tandem solar cells with multilayer TMD films as thin as 10-50 nm could in practice achieve up to 32% power conversion efficiency with today' material quality. These findings underscore the potential of TMD-silicon tandem solar cells to enable the next generation of cost-effective, high-efficiency photovoltaics.",
                "authors": [
                    {
                        "s2_author_id": "2113956734",
                        "name": "Frederick U. Nitta"
                    },
                    {
                        "s2_author_id": "30616755",
                        "name": "Koosha Nassiri Nazif"
                    },
                    {
                        "s2_author_id": "2247702589",
                        "name": "Eric Pop"
                    }
                ]
            },
            {
                "s2_paper_id": "4b0409df881c79b016b1784d3dd1275b05275918",
                "title": "Direct ALD of amorphous MoS2 thin films for extra-terrestrial photovoltaic applications",
                "year": 2025,
                "venue": "Photovoltaic Specialists Conference",
                "citation_count": 0,
                "reference_count": 0,
                "abstract": "The design of solar cells for space applications demands a high power-to-weight ratio and resilience against extreme environments, including proton radiation and rapid temperature fluctuations. However, existing technologies come with drawbacks: III-V materials are expensive, CdTe and CIGS rely on scarce and toxic elements, perovskites suffer from stability issues, and silicon has limited limited tolerance to space-stressors. This study investigates ultra-thin amorphous MoS2 as a viable alternative, offering a balance of affordability, environmental sustainability, and robustness. Using atomic layer deposition (ALD), we enable scalable production of photovoltaic-grade amorphous MoS2 thin films, achieving large-area coatings with exceptional uniformity, smoothness, and precise thickness control. Passivation increases the charge carrier lifetime to approximately 100 ns, highlighting the potential for high specific power in a fully encapsulated module. Additionally, unpassivated films show minimal disorder when exposed to high-energy, high-fluence proton radiation. These results highlight the promise of amorphous MoS2 for space-based photovoltaics and lay the groundwork for further studies on its long-term durability in extraterrestrial conditions.",
                "authors": [
