            {
                "s2_paper_id": "de34f55127bc5f6bbaa905c53a4c962acd112bb6",
                "title": "Precision Temperature Sensing and Digital Control for Microheating Platforms",
                "year": 2025,
                "venue": "Italian National Conference on Sensors",
                "citation_count": 0,
                "reference_count": 10,
                "abstract": "This paper presents a temperature sensing and control method for ovenized micro-heater platforms that requires no integrated active circuits or reference components. It uses thin-film resistors with different temperature coefficients of resistance, fabricated using standard MEMS processes. The system operates with simple off-platform electronics and achieves temperature stability within 0.05 C and a standard deviation below 0.047 C over multiple days, power cycles, and a wide ambient range.",
