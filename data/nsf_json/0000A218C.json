            {
                "s2_paper_id": "7f6f875677e45a0528c3e6ab16eefce8562981e9",
                "title": "Density-functional theory molecular dynamics simulations of a-HfO2/a-SiO2/SiGe and a-HfO2/a-SiO2/Ge with a-SiO2 and a-SiO suboxide interfacial layers",
                "year": 2018,
                "venue": "Applications of Surface Science",
                "citation_count": 11,
                "reference_count": 37,
                "abstract": null,
                "authors": [
