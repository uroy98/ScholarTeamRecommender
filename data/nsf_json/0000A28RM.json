            {
                "s2_paper_id": "52cefe6625bf171b706e8028613f272fb312324b",
                "title": "Effects of incubation temperature on the upper thermal tolerance of the imperiled longfin smelt (Spirinchus thaleichthys)",
                "year": 2024,
                "venue": "Conservation Physiology",
                "citation_count": 1,
                "reference_count": 106,
                "abstract": "Using a common cardiac thermal performance assay, we identified temperature ranges that define the thermal optima and upper thermal limits of the larval life stage of the imperiled longfin smelt larvae. We demonstrated the utility of a cardiac assay for defining appropriate thermal conditions for a species of conservation concern.",
