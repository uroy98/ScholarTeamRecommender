            {
                "s2_paper_id": "818d5fd2a7526f45512a64b0bd951c3072bf3b8b",
                "title": "A systematic review of differences for disabled students in STEM versus other disciplinary undergraduate settings",
                "year": 2025,
                "venue": "Journal of Engineering Education",
                "citation_count": 6,
                "reference_count": 91,
                "abstract": "Engineering education and other discipline\u2010based education researchers may motivate their work with claims that STEM (science, technology, engineering, and mathematics) norms and culture are unique, thus requiring focused study. As research on disabled students gains momentum in engineering education, it is important to understand differences that limit generalizability of prior work in other disciplines to STEM.",
