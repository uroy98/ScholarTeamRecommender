        "papers": [
            {
                "s2_paper_id": "62680373393b444b961b083f8aa913607833c9af",
                "title": "Notas generales sobre la fonolog\u00eda segmental y pros\u00f3dica del Maropa, con menciones acerca de la serie africada",
                "year": 2020,
                "venue": "",
                "citation_count": 0,
                "reference_count": 6,
                "abstract": "This paper discusses the properties of the segmental and suprasegmental phonology of Maropa, an almost extinct Takanan language of Bolivian Amazon. The main processes of vowels and consonants are described to provide with rules on how segments interact in this language. Also, a description on syllable structure and stress assignment unveils that their characteristics are related to prosodic, morphophonological and syntactic domains. Likewise, this document deals with the explanation of the origin of two of the four affricate sounds in Maropa which are present due to historical dissimilation and assimilation according to comparisons with sister languages. I will argue that these sounds evolved from the other two pre existing affricates, and that their diachronic development generated phonological contrast among phonemes.",
