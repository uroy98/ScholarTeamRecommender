                ]
            },
            {
                "s2_paper_id": "1939d18ae33fea63fffe4eb82277de29b5bf4f25",
                "title": "Demo Proposal: Tele-Operated Support over 4G/5G Mobile Communications",
                "year": 2021,
                "venue": "International Mediterranean Conference on Communications and Networking",
                "citation_count": 4,
                "reference_count": 3,
                "abstract": "This demonstration presents the design and implementation of a remote driving (tele-operated) support service over mobile communications with an actual vehicle, in the framework of the 5G-HEART project. Also, it evaluates the performance of existing cellular technologies, which is essential for better understanding and planning remote driving through 5G.",
