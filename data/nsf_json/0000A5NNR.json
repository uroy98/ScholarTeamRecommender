            {
                "s2_paper_id": "10691257a08da60acedfd27ecba8d9b34b8a7af8",
                "title": "Diameter Agent Overload and the Peer Overload Report",
                "year": 2019,
                "venue": "Request for Comments",
                "citation_count": 1,
                "reference_count": 0,
                "abstract": "This specification documents an extension to RFC 7683 (Diameter\nOverload Indication Conveyance (DOIC)) base solution. The extension\ndefines the Peer overload report type. The initial use case for the\nPeer report is the handling of occurrences of overload of a Diameter\nagent. Requirements",
                "authors": [
                    {
                        "s2_author_id": "2595185",
                        "name": "S. Donovan"
                    }
                ]
            },
            {
                "s2_paper_id": "1153c20d7d96e6f0afcd6f7c2aa24371f9e7ac21",
                "title": "Diameter Load Information Conveyance",
                "year": 2019,
                "venue": "Request for Comments",
                "citation_count": 0,
                "reference_count": 0,
                "abstract": "RFC7068 describes requirements for Overload Control in Diameter. This\nincludes a requirement to allow Diameter nodes to send \"load\"\ninformation, even when the node is not overloaded. RFC7683 (Diameter\nOverload Information Conveyance (DOIC)) solution describes a mechanism\nmeeting most of the requirements, but does not currently include the\nability to send load information. This document defines a mechanism\nfor conveying of Diameter load information.",
                "authors": [
                    {
                        "s2_author_id": "2064475025",
                        "name": "B. Campbell"
                    },
                    {
                        "s2_author_id": "2595185",
                        "name": "S. Donovan"
                    },
                    {
                        "s2_author_id": "1395006447",
