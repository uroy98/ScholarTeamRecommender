            },
            {
                "s2_paper_id": "a834939f2f31db46f05e6c09e7c01f2cff39b94a",
                "title": "Diameter Overload Rate Control",
                "year": 2019,
                "venue": "Request for Comments",
                "citation_count": 0,
                "reference_count": 0,
                "abstract": "This specification documents an extension to the Diameter Overload\nIndication Conveyance (DOIC) [RFC7683] base solution. This extension\nadds a new overload control abatement algorithm. This abatement\nalgorithm allows for a DOIC reporting node to specify a maximum rate\nat which a DOIC reacting node sends Diameter requests to the DOIC\nreporting node. Requirements",
                "authors": [
                    {
                        "s2_author_id": "2595185",
