            {
                "s2_paper_id": "a3a4bf90ba960f20c0f036c2bd6a7cb81b6e4972",
                "title": "Precise measurement of the scalar polarizability of $^{115}$In within the $5P_{1/2} \\rightarrow 6S_{1/2}$ transition using an atomic beam",
                "year": 2013,
                "venue": "",
                "citation_count": 0,
                "reference_count": 0,
                "abstract": null,
                "authors": [
                    {
                        "s2_author_id": "90669891",
