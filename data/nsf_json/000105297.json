                    }
                ]
            },
            {
                "s2_paper_id": "3e4f5d367d2f7443eaaf26ecb70a9aa446e5b159",
                "title": "A Precise Measurement of the Stark Shift in the 5$P_{1/2}\\to$ 6$S_{1/2}$ 410nm Transition in Indium",
                "year": 2012,
