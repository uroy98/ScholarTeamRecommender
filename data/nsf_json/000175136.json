        "papers": [
            {
                "s2_paper_id": "73ff65f829b2a14df8ad736c42bf6da8a0333d66",
                "title": "Novel technology for acquiring wheel motion attitude information based on WEIS",
                "year": 2021,
                "venue": "International Symposium on Parameterized and Exact Computation",
                "citation_count": 0,
                "reference_count": 9,
                "abstract": "As the wheel speed sensing methods of anti-lock braking system (ABS) in traditional wheel motion attitude MAP monitoring are mostly limited to measuring the two parameters of wheel angular velocity and angular acceleration, and there are reports that the tire condition test technology by installing three acceleration sensors at specific test points inside the tire to obtain tire condition information cannot further obtain wheel attitude angle, speed, rotation parameter information, etc., this paper proposes a novel technology for acquiring wheel motion attitude information based on WEIS, which calculates and obtains all the MAP information of the wheel by placing an intelligent three-dimensional acceleration sensor unit on the wheel hub and using the wheel MAP monitoring model. The experimental results indicate that the average error of wheel camber angle $\\gamma_{{i}}$ under experimental conditions is 0.0734\u00b0, the average error of wheel tangential velocity vsTi is $0.1480{m}/{s}$, the average error of wheel angular velocity $(j){i}$ is 0. $5420{r}{a}{d}/{s}$ and its relative error is 2.25%. This new technology can measure 11 of the 27 condition monitoring parameters for the safe operation of motor vehicles, and the performance indicators have reached better measurement accuracy and achieved the expected effects.",
