            },
            {
                "s2_paper_id": "84f026adbf65401d1dcbf668983669a6b143fcbb",
                "title": "Gamma camera imaging in an undergraduate physics course",
                "year": 2021,
                "venue": "American Journal of Physics",
                "citation_count": 1,
                "reference_count": 20,
                "abstract": "Gamma camera imaging is an important technique in nuclear medicine. It is capable of diagnostic imaging of metabolically active areas and organ function, and it can be used to evaluate blood flow in the heart muscle, measure bone growth, detect tumors, and perform many other medical studies. It is a real world application that integrates concepts in medicine, nuclear physics, geometric optics, data processing, calibration, and image formation. This paper provides an overview of gamma camera imaging intended for an intermediate-level undergraduate physics course for students majoring in STEM disciplines. Because working with radioactive materials is not practical in our setting, we use an approach involving paper-andpencil exercises, a visible light apparatus, and computer work.",
                "authors": [
                    {
                        "s2_author_id": "144926497",
                        "name": "M. Lowe"
                    },
                    {
                        "s2_author_id": "40303220",
