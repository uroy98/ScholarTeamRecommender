            {
                "s2_paper_id": "05f47689e8050d6b2783cefe283f597b66c7c12c",
                "title": "Reduced Fat Oxidation as a Potential Pathway Linking Early\u2010Life Adversity to Obesity Risk: Evidence From Vanuatu",
                "year": 2026,
                "venue": "American Journal of Human Biology",
                "citation_count": 0,
                "reference_count": 15,
                "abstract": "Adverse environmental conditions during early life can increase the risk of obesity in adulthood, but the underlying mechanisms are not completely understood. Here, we test the hypothesis that early\u2010life adversity leads to a lower metabolic rate and reduced fat oxidation, factors expected to increase fat accumulation.",
