        "h_index": 5,
        "papers": [
            {
                "s2_paper_id": "8d7fbc29ab045e9209ef55131a5e13cbf2c88da7",
                "title": "Multimodal Physiological Assessment of the Task-related Attentional States in a VR Driving Environment",
                "year": 2022,
                "venue": "International Conference on Mechatronics and Machine Vision in Practice",
                "citation_count": 7,
                "reference_count": 16,
                "abstract": "The wandering mind is a significant source of distraction for drivers. There is extensive research studying the wandering mind via driving simulations, on-road driving, and surveys. This research project involved experience sampling in a Unity3D driving simulation environment and physiological sensors including eye tracking, EEG, respiration, temperature, skin conductance, blood volume pulse, and EMG to understand changes in drivers' physiological states that co-occur with mind wandering. The team conducted 33 experimental trials to collect and analyze data to set the stage for further research investigating the relationship between physiological representations and mind wandering. These results will provide guidance for further research in the problem space and potentially impact human factors design of automobiles.",
                "authors": [
                    {
                        "s2_author_id": "2111464571",
                        "name": "Wenchao Zhu"
                    },
                    {
                        "s2_author_id": "3348175",
                        "name": "A. Kucyi"
                    },
                    {
                        "s2_author_id": "2172224901",
                        "name": "A. Kramer"
                    },
                    {
                        "s2_author_id": "46396414",
                        "name": "Ying-Fan Lin"
                    }
                ]
            },
            {
                "s2_paper_id": "f247238bce86c34112b41c11fbdbf64873ab987c",
                "title": "An Objective Pain Measurement Machine Learning Model through Facial Expressions and Physiological Signals",
                "year": 2022,
                "venue": "International Conference on Mechatronics and Machine Vision in Practice",
                "citation_count": 5,
                "reference_count": 12,
                "abstract": "The widely used technique for measuring patient pain in modern medicine is based on patients' self-reported pain. Since each human body experiences pain differently and has its own distinct pain threshold, it is very difficult for professionals to objectively evaluate a patient's level of pain based on their own description. In order for pain management treatments and prescribed therapy to be efficient and effective, a precise evaluation of pain is crucial. This study developed an objective pain measurement model based on machine learning algorithms and an open-source BioVid heat pain database. More specifically, the properties of skin conductance at various pain thresholds were examined. Electrocardiogram (ECG) and facial expression data were also assessed for performance. The study's findings demonstrate that both facial expression-based and ECG-based models can detect whether a patient is in pain. The physiological response of the subject can be utilized as a nonverbal test to gauge the patient's level of discomfort. The ECG-based model is more precise than the one based on facial expressions because we are able to gather more data with the former, therefore improving the model's accuracy, by increasing the period of the pain stimulation and the number of participants.",
                "authors": [
                    {
                        "s2_author_id": "2208533679",
                        "name": "Jianan Zheng"
                    },
                    {
                        "s2_author_id": "46396414",
                        "name": "Ying-Fan Lin"
                    }
                ]
            },
            {
                "s2_paper_id": "8b522fde0ce49dac50e0348aebc941a87ec25fd4",
                "title": "Driving Anger States Detection Based on Incremental Association Markov Blanket and Least Square Support Vector Machine",
                "year": 2019,
                "venue": "Discrete Dynamics in Nature and Society",
                "citation_count": 19,
                "reference_count": 59,
                "abstract": "Driving anger, known as \u201croad rage\u201d, has gradually become a serious traffic psychology issue. Although driving anger identification is solved in some studies, there is still a gap in driving anger grading which is helpful to take different intervening measures for different anger intensity, especially in real traffic environment. The main objectives of this study are: (1) explore a novel driving anger induction method based on various elicitation events, e.g., traffic congestion, vehicles weaving/cutting in line, jaywalking and red light waiting in real traffic environment; (2) apply incremental association Markov blanket (IAMB) algorithm to select typical features related to driving anger states; (3) employ least square support vector machine (LSSVM) to identify different driving anger states based on the selected features. Thirty private car drivers were enrolled to perform field experiments on a busy route selected in Wuhan, China, where drivers\u2019 anger could be induced by the elicitation events within limited time. Meanwhile, three types of data sets including driver physiology, driving behaviors and vehicle motions, were collected by multiple sensors. The results indicate that 13 selected features including skin conductance, relative energy spectrum of \u03b2 band of electroencephalogram, standard deviation (SD) of pedaling speed of gas pedal, SD of steering wheel angle rate, vehicle speed, SD of speed, SD of forward acceleration and SD of lateral acceleration have significant impact on driving anger states. The IAMB-LSSVM model achieves an accuracy with 82.20% which is 2.03%, 3.15%, 4.34%, 7.84% and 8.36% higher than IAMB using C4.5, NBC, SVM, KNN and BPNN, respectively. The results are beneficial to design driving anger detecting or intervening devices in intelligent human-machine systems.",
                "authors": [
