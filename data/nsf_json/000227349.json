            {
                "s2_paper_id": "66228f85bc67c9f1b73c7a10e012888ac9959d04",
                "title": "Evaluating high order discontinuous Galerkin discretization of the Boltzmann collision integral in \\begin{document}$ \\mathcal{O}(N^2) $\\end{document} operations using the discrete fourier transform",
                "year": 2019,
                "venue": "Kinetic and Related Models",
                "citation_count": 5,
                "reference_count": 0,
                "abstract": "We present a numerical algorithm for evaluating the Boltzmann collision operator with \\begin{document}$O(N^2)$\\end{document} operations based on high order discontinuous Galerkin discretizations in the velocity variable. To formulate the approach, Galerkin projection of the collision operator is written in the form of a bilinear circular convolution. An application of the discrete Fourier transform allows to rewrite the six fold convolution sum as a three fold weighted convolution sum in the frequency space. The new algorithm is implemented and tested in the spatially homogeneous case, and results in a considerable improvement in speed as compared to the direct evaluation. Split and non-split forms of the collision operator are considered, which are forms of the collision operator that have separate and simultaneous evaluations of the gain and loss terms, respectively. Smaller numerical errors are observed in the conserved quantities in simulations using the non-split form.",
                "authors": [
                    {
                        "s2_author_id": "32830977",
                        "name": "A. Alekseenko"
                    },
                    {
                        "s2_author_id": "12730469",
                        "name": "J. Limbacher"
                    }
                ]
            },
            {
                "s2_paper_id": "0574335c399f25107b4e517d9e88e785ecf9e99e",
                "title": "Evaluating High Order Discontinuous Galerkin Discretization of the Boltzmann Collision Integral in $O(N^2)$ Operations Using the Discrete Fourier Transform",
                "year": 2018,
                "venue": "",
                "citation_count": 4,
                "reference_count": 45,
                "abstract": "We present a numerical algorithm for evaluating the Boltzmann collision operator with $O(N^2)$ operations based on high order discontinuous Galerkin discretizations in the velocity variable. To formulate the approach, Galerkin projection of the collision operator is written in the form of a bilinear circular convolution. An application of the discrete Fourier transform allows to rewrite the six fold convolution sum as a three fold weighted convolution sum in the frequency space. The new algorithm is implemented and tested in the spatially homogeneous case, and results in a considerable improvement in speed as compared to the direct evaluation. Simultaneous and separate evaluations of the gain and loss terms of the collision operator were considered. Less numerical error was observed in the conserved quantities with simultaneous evaluation.",
                "authors": [
                    {
                        "s2_author_id": "32830977",
                        "name": "A. Alekseenko"
                    },
