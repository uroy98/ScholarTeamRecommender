                "s2_paper_id": "1786cb6f6c2d0af30661e902ecdcce43802e4fd1",
                "title": "Revolution and Dictatorship: The Violent Origins of Durable Authoritarianism. By Steven Levitsky and Lucan Way",
                "year": 2023,
                "venue": "Journal of Social History",
                "citation_count": 4,
                "reference_count": 0,
                "abstract": null,
                "authors": [
                    {
                        "s2_author_id": "47448770",
