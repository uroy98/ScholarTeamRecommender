            {
                "s2_paper_id": "2715d21747febccc4b1f61fb96f1b0030749cf2e",
                "title": "Quasisymmetry and solidity of quasiconformal maps in metric spaces",
                "year": 2023,
                "venue": "Studia Mathematica",
                "citation_count": 0,
                "reference_count": 0,
                "abstract": null,
                "authors": [
                    {
                        "s2_author_id": "2113570883",
