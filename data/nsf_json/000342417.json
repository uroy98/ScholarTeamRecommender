            {
                "s2_paper_id": "4e7521c14ca8e1ffa79d830724c45caa2543b9a2",
                "title": "Regularity for solutions of the two-phase Stefan problem",
                "year": 2005,
                "venue": "",
                "citation_count": 5,
                "reference_count": 12,
                "abstract": "We consider the two-phase Stefan problem $u_t=\\Delta\\alpha(u)$ where \n$\\alpha(u) =u+1$ for $u<-1$, $\\alpha(u) =0$ for $-1 \\leq u \\leq 1$, \nand $\\alpha(u)=u-1$ for $u \\geq 1$. We show that if $u$ is an \n$L_{l o c}^2$ distributional solution then $\\alpha(u)$ has $L_{l o c}^2$ \nderivatives in time and space. We also show $|\\alpha(u)|$ is \nsubcaloric and conclude that $\\alpha(u)$ is continuous.",
                "authors": [
                    {
                        "s2_author_id": "101759298",
                        "name": "M. Korten"
                    },
                    {
                        "s2_author_id": "144042887",
                        "name": "C. N. Moore"
                    }
                ]
            },
            {
                "s2_paper_id": "c2bb34036770b4c2a5a5fad181b7b85fa6e89b5f",
                "title": "The Hele-Shaw problem as a\"Mesa\"limit of Stefan problems: Existence, uniqueness, and regularity of the free boundary",
                "year": 2004,
                "venue": "",
                "citation_count": 0,
                "reference_count": 18,
                "abstract": "We study a Hele-Shaw problem with a mushy region obtained as a Mesa type limit of one phase Stefan problems in exterior domains. We study the convergence, determine some of the qualitative properties and regularity of the unique limiting solution, and prove regularity of the free boundary of this limit under very general conditions on the initial data. Indeed, our results handle changes in topology and multiple injection slots.",
                "authors": [
