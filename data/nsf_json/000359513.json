                    }
                ]
            },
            {
                "s2_paper_id": "99d317e37c6d10542282f0f043c9bb25c7029c35",
                "title": "Thoughts on Learning Human and Programming Languages",
                "year": 2024,
                "venue": "Computing in science & engineering (Print)",
                "citation_count": 0,
                "reference_count": 0,
                "abstract": "This is a virtual dialog between Jeffrey C. Carver and Daniel S. Katz on how people learn programming languages. It\u2019s based on a talk Jeff gave at the first US-RSE Conference (US-RSE\u201923), which led Dan to think about human languages versus computer languages. Dan discussed this with Jeff at the conference, and this discussion continued asynchronous, with this column being a record of the discussion.",
                "authors": [
                    {
                        "s2_author_id": "2247527607",
