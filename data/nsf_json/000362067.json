                    }
                ]
            },
            {
                "s2_paper_id": "49e273619ff95baa9e3c7c36e589d710f5185f3e",
                "title": "Accuracy Assessment of Antenna Patterns Using Unmanned Aerial Vehicle (UAV) Platforms",
                "year": 2023,
                "venue": "IEEE Conference on Antenna Measurements & Applications",
                "citation_count": 1,
                "reference_count": 21,
                "abstract": "This paper investigates the influence of UAV platform positioning accuracy on the precision of far-field antenna measurements conducted using UAVs. A mathematical model that incorporates position errors of the UAV platform, frequency, and AUT size is used to estimate both amplitude and phase errors in the measurements. The proposed model was used validated with measurements from a small antenna array at 3 GHz. Antenna measured antenna patterns presents excellent performance.",
