            {
                "s2_paper_id": "4f66b23ea7d652e287144d902c33ac03b78b794c",
                "title": "Effects of different cooking methods on free fatty acid profile, water-soluble compounds and flavor compounds in Chinese Piao chicken meat.",
                "year": 2021,
                "venue": "Food Research International",
                "citation_count": 81,
                "reference_count": 36,
                "abstract": "Piao chicken breast meat was cooked by three different methods (boiling, frying and roasting). Non-volatile and volatile substances in the three cooked chicken were analyzed by GC-MS, UPLC-Q-Exactive-MS and GC-IMS, respectively. Arachidonic acid was the highest in boiled chicken, oleic acid was the highest in roasted chicken, linoleic acid, EPA and DHA were the highest in fried chicken. Compared with the control group, the total content of small molecular metabolites of chicken in each treatment group decreased. The total amount of amino acids in roasted chicken was 2.90 times of that in boiled chicken (P\u00a0<\u00a00.05), and 2.23 times of that in fried chicken (P\u00a0<\u00a00.05). A total of 26 volatile flavor compounds were detected. Phenylacetaldehyde etc. were the main volatile flavor compounds in boiled chicken, 3-butanedione etc. were the main volatile flavor compounds in fried chicken, while 3-methylbutyraldehyde etc. were the main volatile flavor compounds in roasted chicken.",
                "authors": [
                    {
                        "s2_author_id": "1576164044",
                        "name": "Yuanrui Yu"
                    },
                    {
                        "s2_author_id": "2118561573",
                        "name": "Guiying Wang"
                    },
                    {
                        "s2_author_id": "2152096362",
