                    }
                ]
            },
            {
                "s2_paper_id": "2309fbad6771ec1d84e2f48f8f186845ce1cc468",
                "title": "Tibetan Sentiment Classification Method Based on Semi-Supervised Recursive Autoencoders",
                "year": 2019,
                "venue": "Computers Materials & Continua",
                "citation_count": 4,
                "reference_count": 17,
                "abstract": ": We apply the semi-supervised recursive autoencoders (RAE) model for the sentiment classification task of Tibetan short text, and we obtain a better classification effect. The input of the semi-supervised RAE model is the word vector. We crawled a large amount of Tibetan text from the Internet, got Tibetan word vectors by using Word2vec, and verified its validity through simple experiments. The values of parameter \u03b1 and word vector dimension are important to the model effect. The experiment results indicate that when \u03b1 is 0.3 and the word vector dimension is 60, the model works best. Our experiment also shows the effectiveness of the semi-supervised RAE model for Tibetan sentiment classification task and suggests the validity of the Tibetan word vectors we trained.",
                "authors": [
                    {
                        "s2_author_id": "49602675",
                        "name": "Xiaodong Yan"
                    },
