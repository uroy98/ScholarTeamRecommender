            {
                "s2_paper_id": "32ab29856da8977b3ff39cb1365852ac8086249b",
                "title": "Partial Dynamical Systems and AF C*-algebras",
                "year": 2003,
                "venue": "",
                "citation_count": 7,
                "reference_count": 32,
                "abstract": "We obtain a characterization in terms of dynamical systems of those r-discrete groupoids for which the groupoid C*-algebra is approximately finite-dimensional (AF). These ideas are then used to compute the K-theory for AF algebras by utilizing the actions of these partial homeomorphisms, and these K-theoretic calculations are applied to some specific examples of AF algebras. Finally, we show that, for a certain class of dimension groups, a groupoid can be obtained directly from the dimension group's structure whose associated C*-algebra has its dimension group isomorphic to the original dimension group.",
                "authors": [
                    {
                        "s2_author_id": "78289582",
                        "name": "J. Peters"
                    },
                    {
                        "s2_author_id": "2112378",
                        "name": "R. Zerr"
                    }
                ]
            },
            {
                "s2_paper_id": "9826b7b7c08c404d69ef8eb1457a0775d91b5972",
                "title": "Minimal Bratteli diagrams and the dimension groups of AF C*-algebras",
                "year": 2003,
                "venue": "International Journal of Mathematics and Mathematical Sciences",
                "citation_count": 2,
                "reference_count": 27,
                "abstract": "A method is described which identifies a wide variety of AF algebra dimension groups with groups of continuous functions. The results here generalize the well-known fact that commutative AF algebras have dimension groups which can be identified with groups of integer-valued continuous functions.",
                "authors": [
                    {
                        "s2_author_id": "2112378",
                        "name": "R. Zerr"
                    }
                ]
            },
