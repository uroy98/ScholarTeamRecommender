            {
                "s2_paper_id": "896491d03663640ce63d50c8921ff3cb0675c144",
                "title": "Convex decomposition theory",
                "year": 2001,
                "venue": "",
                "citation_count": 76,
                "reference_count": 26,
                "abstract": "We use convex decomposition theory to (1) reprove the existence of a universally tight contact structure on every irreducible 3-manifold with nonempty boundary, and (2) prove that every toroidal 3-manifold carries infinitely many nonisotopic, nonisomorphic tight contact structures.",
