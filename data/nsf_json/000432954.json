            {
                "s2_paper_id": "8a370bff857ae1159aa677603137118160cf6835",
                "title": "The identification problem for the attenuated X-ray transform",
                "year": 2011,
                "venue": "",
                "citation_count": 14,
                "reference_count": 40,
                "abstract": "We study the problem of recovery both the attenuation $a$ and the source $f$ in the attenuated X-ray\ntransform in the plane. We study the linearization as well. It turns out that there is a natural\nHamiltonian flow that determines which singularities we can recover. If the perturbation $\\delta a$\nis supported in a compact set that is non-trapping for that flow, then the problem is well posed.\nOtherwise, it may not be, and least in the case of radial $a$, $f$, it is not. We present uniqueness\nand non-uniqueness results for both the linearized and the non-linear problem; as well as a H\\\"older\nstability estimate.",
                "authors": [
                    {
                        "s2_author_id": "2060600244",
                        "name": "P. Stefanov"
                    }
                ]
            },
