            {
                "s2_paper_id": "f12f0d1402e2294d8e9ae6cde924a402c623139d",
                "title": "Inverse Boundary Problem for the Two Photon Absorption Transport Equation",
                "year": 2021,
                "venue": "SIAM Journal on Mathematical Analysis",
                "citation_count": 6,
                "reference_count": 31,
                "abstract": "In this work we study the inverse boundary problem for two photon absorption radiative transport equation. Two photon absorption happens when it takes two photons to excite a molecule from one state to another [19,25]. The probability of two photon absorption at a given point is proportional to the light intensity there regardles of the incoming direction. Let \u03a9 \u2282 R, n \u2265 2 be an open bounded convex set with a C1 boundary \u2202\u03a9, and let Sn\u22121 be the unit sphere in R, \u0393\u00b1 = {(x, \u03b8) \u2208 \u2202\u03a9 \u00d7 Sn\u22121 | \u00b1n(x) \u00b7 \u03b8 > 0}, where n(x) is the outer normal at x \u2208 \u2202\u03a9. Denote by u(x, \u03b8) the photon density function at spatial location x \u2208 \u03a9 in the direction \u03b8 \u2208 Sn\u22121. Then our model is the following equation, see also [18],",
                "authors": [
                    {
                        "s2_author_id": "2060600244",
                        "name": "P. Stefanov"
                    },
                    {
                        "s2_author_id": "5019660",
                        "name": "Yimin Zhong"
                    }
                ]
            },
            {
                "s2_paper_id": "1a000d06a4216f8ca9c4ec77e24327c512d0ece5",
                "title": "Sampling linear inverse problems with noise",
                "year": 2020,
                "venue": "Asymptotic Analysis",
                "citation_count": 7,
                "reference_count": 22,
                "abstract": "We study the effect of additive noise to the inversion of FIOs associated to a diffeomorphic canonical relation. We use the microlocal defect measures to measure the power spectrum of the noise in the phase space and analyze how that power spectrum is transformed under the inversion. In general, white noise, for example, is mapped to noise depending on the position and on the direction. In particular, we compute the standard deviation, locally, of the noise added to the inversion as a function of the standard deviation of the noise added to the data. As an example, we study the Radon transform in the plane in parallel and fan-beam coordinates, and present numerical examples.",
                "authors": [
                    {
                        "s2_author_id": "2060600244",
                        "name": "P. Stefanov"
                    },
                    {
                        "s2_author_id": "2974252",
                        "name": "S. Tindel"
                    }
                ]
            },
            {
                "s2_paper_id": "099bcf66766c1c0f44487837ef9c548a0e12ebce",
                "title": "Semiclassical Sampling and Discretization of Certain Linear Inverse Problems",
                "year": 2018,
                "venue": "SIAM Journal on Mathematical Analysis",
                "citation_count": 18,
                "reference_count": 36,
                "abstract": "We study sampling of Fourier Integral Operators $A$ at rates $sh$ with $s$ fixed and $h$ a small parameter. We show that the Nyquist sampling limit of $Af$ and $f$ are related by the canonical relation of $A$ using semiclassical analysis. We apply this analysis to the Radon transform in the parallel and the fan-beam coordinates. We explain and illustrate the optimal sampling rates for $Af$, the aliasing artifacts, and the effect of averaging (blurring) the data $Af$. We prove a Weyl type of estimate on the minimal number of sampling points to recover $f$ stably in terms of the volume of its semiclassical wave front set.",
                "authors": [
                    {
                        "s2_author_id": "2060600244",
                        "name": "P. Stefanov"
                    }
                ]
            },
