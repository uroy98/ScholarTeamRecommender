                "s2_paper_id": "d35383ae69fe68daf32fa91acf42665573db4703",
                "title": "Math for America Los Angeles: Lessons Learned from 10 Years of Teacher-Centered Leadership Development.",
                "year": 2019,
                "venue": "",
                "citation_count": 0,
                "reference_count": 58,
