            {
                "s2_paper_id": "e43dfe961bfe4b0f7882fbe21acb9b2adfbee2c3",
                "title": "The skew-Maass lift I",
                "year": 2018,
                "venue": "Research in the Mathematical Sciences",
                "citation_count": 1,
                "reference_count": 38,
                "abstract": "The classical Maass lift is a map from holomorphic Jacobi forms to holomorphic scalar-valued Siegel modular forms. Automorphic representation theory predicts a non-holomorphic and vector-valued analogue for Hecke eigenforms. This paper is the first part of a series of papers. In this series of papers, we provide an explicit construction of the non-holomorphic Maass lift that is linear and also applies to non-eigenforms. In this first part, we develop new techniques to study Fourier series expansions of Siegel modular forms, which allow us to construct a Maass lift from harmonic Maass\u2013Jacobi forms to scalar-valued Maass\u2013Siegel forms.",
                "authors": [
                    {
                        "s2_author_id": "2763834",
                        "name": "Martin Raum"
                    },
                    {
                        "s2_author_id": "31993704",
                        "name": "Olav K. Richter"
                    }
                ]
            },
