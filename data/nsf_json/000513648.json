            {
                "s2_paper_id": "c863bff820d60a2a043124b0c309209a7d411018",
                "title": "Formation of synthetically relevant CF3-substituted phenonium ions in superacid media",
                "year": 2021,
                "venue": "RSC Advances",
                "citation_count": 0,
                "reference_count": 75,
                "abstract": "Predestined to be transient theoretical species, phenonium ions can now be considered as cationic intermediates of choice in organic synthesis. Here, we demonstrate that under non-nucleophilic and superacidic conditions, CF3-substituted phenonium ions can be generated to furnish original CF3-substituted dihydrostilbenes of interest.",
