            {
                "s2_paper_id": "508c514379d453b42ebad9c236e62f18ff964f89",
                "title": "Critical junctures in the shaping of citizenship in Ethiopia",
                "year": 2025,
                "venue": "Journal of Eastern African Studies",
                "citation_count": 0,
                "reference_count": 93,
                "abstract": "ABSTRACT The \u2018national question\u2019 is an enduring one in Ethiopia. While the 1995 constitution was an attempt to provide a more inclusive set of institutions, it also struck at the heart of some of the citizenship and belonging debates that have animated decades of conflict. While somewhat expected, the depth of the violence of the transition period and the fraying of the bonds of national unity have been shocking to many. In this paper, we focus on the evolution of the language and practices of meaningful citizenship that has both shaped and been the product of evolving understandings of national identity for Ethiopian elites and ordinary citizens alike. Using an interpretive methodology to analyze particular \u2018critical junctures,\u2019 we point to the ways that the dynamics of violence and division were not inevitable, but were the product of specific actions and therefore, amenable again to new social and political adaptation. We suggest here the potential for a common citizenship understanding that could form the basis of a national dialogue.",
                "authors": [
                    {
                        "s2_author_id": "39382115",
                        "name": "Lahra Smith"
                    },
                    {
                        "s2_author_id": "2404852370",
                        "name": "Bethania Michael"
                    }
                ]
            },
            {
                "s2_paper_id": "acf1eeab36f32c4b39971d6ac2004262a861e620",
                "title": "Reflections on an Institutional Journey Toward Enhancing Diversity, Equity, and Inclusion in Political Science",
                "year": 2023,
                "venue": "PS: Political Science & Politics",
                "citation_count": 0,
                "reference_count": 56,
                "abstract": "ABSTRACT As the political and social challenges facing the world multiply, the discipline of political science requires better tools and creative approaches advanced by a more diverse set of researchers. Yet the discipline has struggled to recruit and admit to graduate programs, and retain as faculty, women and underrepresented minorities. Many individual faculty, departments, and universities have developed innovative programs and sought to create structural changes to address these gaps. This article presents the approach taken by the Department of Government at Georgetown University: launching a week-long Political Science Predoctoral Summer Institute in 2022. We describe the Institute\u2019s contours and structure, provide preliminary data on outcomes, and conclude by offering three ideas for expanding and advancing these types of initiatives across the discipline.",
                "authors": [
                    {
                        "s2_author_id": "2052388664",
                        "name": "Ankushi Mitra"
                    },
                    {
                        "s2_author_id": "152198434",
                        "name": "Diana Kapiszewski"
                    },
                    {
                        "s2_author_id": "2247764670",
                        "name": "Thijs Kleinpaste"
                    },
                    {
                        "s2_author_id": "39382115",
                        "name": "Lahra Smith"
                    }
                ]
            },
            {
                "s2_paper_id": "4a1a5ab3fd389a91dbc68de151e95f77750348bf",
                "title": "How Should Clinicians Express Solidarity With Asylum Seekers at the US-Mexico Border?",
                "year": 2022,
                "venue": "AMA journal of ethics",
                "citation_count": 8,
                "reference_count": 51,
                "abstract": "Migrants along the US-Mexico border have been subjected to transnational violence created by international policy, militaristic intervention, and multinational organizational administration of border operations. The COVID-19 pandemic compounded migrants' vulnerabilities and provoked several logistical and ethical problems for US-based clinicians and organizations. This commentary examines how the concept of transnational solidarity facilitates analysis of clinicians' and migrants' shared historical and structural vulnerabilities. This commentary also suggests how actions implemented by one organization in Tijuana, Mexico, could be scaled more broadly for care of migrants and asylum seekers in other transnational health care settings.",
                "authors": [
                    {
                        "s2_author_id": "2105899984",
                        "name": "Carlos Martinez"
                    },
                    {
                        "s2_author_id": "36386333",
