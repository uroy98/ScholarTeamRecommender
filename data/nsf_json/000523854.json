            {
                "s2_paper_id": "f17212b0827a25d72ca8e8d157ed77fd3748e816",
                "title": "Design of an electron microscope phase plate using a focused continuous-wave laser",
                "year": 2010,
                "venue": "New Journal of Physics",
                "citation_count": 66,
                "reference_count": 35,
