        "h_index": 0,
        "papers": [
            {
                "s2_paper_id": "48e473cdd824443c49423570864bd33b9ee521b3",
                "title": "Chemical defects as Li+ ion traps: a theoretical study.",
                "year": 2025,
                "venue": "Chemical Communications",
                "citation_count": 0,
                "reference_count": 0,
                "abstract": "We investigate how sp3 quantum defects on single-walled carbon nanotubes act as atomic-scale traps for individual lithium ions. Density functional theory (DFT) calculations show that endohedrally incorporated Li+ in (7,5) single-walled carbon nanotubes preferentially localize near aryl-hydroxyl sp3 defects, with a binding energy of \u223c2.95 eV. This defect-ion interaction redistributes local charge, perturbs frontier orbitals, and produces a 437 meV red-shift in the defect absorption spectrum, as revealed by time-dependent DFT. These findings highlight the sensitivity of quantum defects to ions, with implications for ion detection, quantum emitters, and lithium storage in carbon nanotube-based electrodes.",
                "authors": [
