        "papers": [
            {
                "s2_paper_id": "1592413cce97b5353124ad24ab402b8bb7a758d5",
                "title": "Adversarial Attacks on Machine Learning Models in Healthcare Applications",
                "year": 2024,
                "venue": "SINTEZA",
                "citation_count": 1,
                "reference_count": 13,
                "abstract": ": With the accelerated development of software tools, fast lifestyle, and expensive healthcare, many healthcare applications have been developed in recent years. With the help of artificial intelligence, apps can significantly improve people's lives, solving various dilemmas regarding their health. As medicine is based on statistics, AI can be remarkably useful and accurate for healthcare applications, but there are potential vulnerabilities found in them too. AI can be both an excellent co-worker for improving apps and a great tool for hackers to steal data or compromise the operation of the application. This paper will propose AI algorithms in healthcare applications and their potential vulnerability to adversarial attacks.",
                "authors": [
                    {
                        "s2_author_id": "2310086194",
                        "name": "Aleksandar Stankovi\u0107"
                    },
                    {
                        "s2_author_id": "2309738358",
                        "name": "Marina Marjanovi\u0107"
                    }
                ]
            },
            {
                "s2_paper_id": "270569c6b23c88c5a474c9a87eeeb6cd48b86b4b",
                "title": "CNN Vulnerability On Untargeted Adversarial Attacks",
                "year": 2024,
                "venue": "Telecommunications Forum",
                "citation_count": 1,
                "reference_count": 15,
                "abstract": "Convolutional Neural Networks (CNNs) are widely used in various AI-driven industries, including healthcare, autonomous systems, and cybersecurity, due to their high accuracy in image classification. However, these models are vulnerable to adversarial attacks, where small, imperceptible perturbations in input data can cause incorrect predictions. This study evaluates the impact of five adversarial attacks: Fast Gradient Sign Method (FGSM), Iterative FGSM (IFGSM), Momentum Iterative FGSM (MIFGSM), Deepfool, and OnePixel Attack on the accuracy of a CNN trained on the CIFAR-10 dataset. Each attack is analyzed for its unique influence on model performance, revealing significant accuracy drops under adversarial conditions. The results are analyzed and illustrate the potential security risks of adversarial attacks, underscoring the need for robust defenses in CNN based systems.",
                "authors": [
                    {
                        "s2_author_id": "2310086194",
                        "name": "Aleksandar Stankovi\u0107"
                    },
