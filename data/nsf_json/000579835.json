                "s2_paper_id": "6cd4255c3b88381654dac048e5cd926dba5e8150",
                "title": "Measuring integrated understanding of undergraduate chemistry research experiences: Assessing oral and written research artifacts",
                "year": 2021,
                "venue": "Chemistry Education Research and Practice",
                "citation_count": 3,
                "reference_count": 0,
                "abstract": "Understanding the impact of undergraduate research experiences (UREs) and course-based undergraduate research experiences (CUREs) is crucial as universities debate the value of allocating scarce resources to these activities. We report...",
                "authors": [
